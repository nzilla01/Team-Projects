@page "/transactions"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject TransactionService TransactionService
@inject CategoryService CategoryService
@using FinTrack.Client.Services
@using FinTrack.Shared.DTOs

<PageTitle>Transactions — FinTrack</PageTitle>

<!-- Toolbar -->
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; flex-wrap:wrap; gap:12px;">
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <select class="form-control" style="width:auto;" @onchange="OnTypeFilter">
            <option value="">All Types</option>
            <option value="Income">Income only</option>
            <option value="Expense">Expenses only</option>
        </select>
    </div>
    <button class="btn btn-primary" @onclick="OpenAddModal">+ Add Transaction</button>
</div>

<!-- Summary pills -->
@if (transactions.Any())
{
    <div style="display:flex; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
        <span style="background:var(--teal-light); color:var(--teal-dark); font-size:13px;
                     font-weight:500; padding:4px 14px; border-radius:100px;">
            @transactions.Count transaction@(transactions.Count != 1 ? "s" : "")
        </span>
        <span style="background:#E1F5EE; color:#085041; font-size:13px;
                     font-weight:500; padding:4px 14px; border-radius:100px;">
            Income: +$@transactions.Where(t => t.Type == "Income").Sum(t => t.Amount).ToString("N2")
        </span>
        <span style="background:#FCEBEB; color:#791F1F; font-size:13px;
                     font-weight:500; padding:4px 14px; border-radius:100px;">
            Expenses: -$@transactions.Where(t => t.Type == "Expense").Sum(t => t.Amount).ToString("N2")
        </span>
    </div>
}

<!-- Transaction list -->
<div class="card">
    @if (isLoading)
    {
        <p style="color:var(--text-secondary); padding:20px 0;">Loading transactions...</p>
    }
    else if (!transactions.Any())
    {
        <div style="text-align:center; padding:40px 0;">
            <div style="font-size:40px; margin-bottom:12px;">💳</div>
            <p style="color:var(--text-secondary); margin-bottom:16px;">
                @(string.IsNullOrEmpty(typeFilter)
                    ? "No transactions yet. Click \"Add Transaction\" to get started."
                    : $"No {typeFilter.ToLower()} transactions found.")
            </p>
            <button class="btn btn-primary" @onclick="OpenAddModal">+ Add Transaction</button>
        </div>
    }
    else
    {
        <div class="transaction-list">
            @foreach (var t in transactions)
            {
                <div class="transaction-item">
                    <div class="transaction-icon"
                         style="background:@(t.CategoryColor)22;">
                        @t.CategoryIcon
                    </div>
                    <div class="transaction-info">
                        <div class="transaction-name">@t.Description</div>
                        <div class="transaction-category">
                            @t.CategoryName · @t.Date.ToString("MMM d, yyyy")
                        </div>
                    </div>
                    <div class="transaction-amount @t.Type.ToLower()">
                        @(t.Type == "Income" ? "+" : "-")$@t.Amount.ToString("N2")
                    </div>
                    <div class="transaction-actions">
                        <button class="btn btn-secondary btn-sm btn-icon"
                                title="Edit"
                                @onclick="() => OpenEditModal(t)">✏️</button>
                        <button class="btn btn-danger btn-sm btn-icon"
                                title="Delete"
                                @onclick="() => ConfirmDelete(t)">🗑️</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Add / Edit Modal -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal" @onclick:stopPropagation>
            <div class="modal-header">
                <span class="modal-title">@(editId.HasValue ? "Edit" : "Add") Transaction</span>
                <button class="btn btn-secondary btn-sm btn-icon" @onclick="CloseModal">✕</button>
            </div>

            @if (!string.IsNullOrEmpty(errorMsg))
            {
                <div class="alert alert-error">@errorMsg</div>
            }

            <div class="form-group">
                <label class="form-label">Type</label>
                <select class="form-control" @bind="form.Type">
                    <option value="Expense">Expense</option>
                    <option value="Income">Income</option>
                </select>
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Amount ($)</label>
                    <input class="form-control" type="number" step="0.01" min="0.01"
                           placeholder="0.00" @bind="form.Amount" />
                </div>
                <div class="form-group">
                    <label class="form-label">Date</label>
                    <input class="form-control" type="date"
                           value="@form.Date.ToString("yyyy-MM-dd")"
                           @onchange="OnDateChange" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Category</label>
                <select class="form-control" @bind="form.CategoryId">
                    <option value="0">-- Select a category --</option>
                    @foreach (var cat in categories.Where(c => c.Type == form.Type))
                    {
                        <option value="@cat.Id">@cat.Icon @cat.Name</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Description</label>
                <input class="form-control"
                       placeholder="What was this for?"
                       @bind="form.Description" @bind:event="oninput" />
            </div>

            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn btn-primary" @onclick="SaveTransaction" disabled="@isSaving">
                    @(isSaving ? "Saving..." : (editId.HasValue ? "Update" : "Add"))
                </button>
            </div>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirm && deletingTransaction != null)
{
    <div class="modal-overlay" @onclick="() => showDeleteConfirm = false">
        <div class="modal" @onclick:stopPropagation style="max-width:380px;">
            <div class="modal-header">
                <span class="modal-title">Delete Transaction</span>
            </div>
            <p style="font-size:14px; color:var(--text-secondary); margin-bottom:8px;">
                Are you sure you want to delete this transaction?
            </p>
            <p style="font-size:14px; font-weight:500;">
                @deletingTransaction.Description —
                $@deletingTransaction.Amount.ToString("N2")
            </p>
            <div class="modal-actions">
                <button class="btn btn-secondary"
                        @onclick="() => showDeleteConfirm = false">Cancel</button>
                <button class="btn btn-danger"
                        @onclick="DeleteConfirmed">Delete</button>
            </div>
        </div>
    </div>
}

@code {
    // ── State ────────────────────────────────────────────────────────────────
    private List<TransactionDto> transactions = new();
    private List<CategoryDto>   categories   = new();
    private bool isLoading = true;
    private bool showModal = false;
    private bool showDeleteConfirm = false;
    private bool isSaving = false;
    private int? editId = null;
    private string errorMsg = "";
    private string typeFilter = "";
    private CreateTransactionDto form = new();
    private TransactionDto? deletingTransaction;

    // ── Lifecycle ────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAll();
        await LoadTransactions();
    }

    // ── Data ─────────────────────────────────────────────────────────────────
    private async Task LoadTransactions()
    {
        isLoading = true;
        transactions = await TransactionService.GetAll(
            type: string.IsNullOrEmpty(typeFilter) ? null : typeFilter);
        isLoading = false;
    }

    private async Task OnTypeFilter(ChangeEventArgs e)
    {
        typeFilter = e.Value?.ToString() ?? "";
        await LoadTransactions();
    }

    // ── Modal ─────────────────────────────────────────────────────────────────
    private void OpenAddModal()
    {
        form   = new CreateTransactionDto { Date = DateTime.Today, Type = "Expense" };
        editId = null;
        errorMsg = "";
        showModal = true;
    }

    private void OpenEditModal(TransactionDto t)
    {
        form = new CreateTransactionDto
        {
            CategoryId  = t.CategoryId,
            Amount      = t.Amount,
            Description = t.Description,
            Date        = t.Date,
            Type        = t.Type
        };
        editId   = t.Id;
        errorMsg = "";
        showModal = true;
    }

    private void CloseModal() { showModal = false; errorMsg = ""; }

    private void OnDateChange(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var d)) form.Date = d;
    }

    private async Task SaveTransaction()
    {
        errorMsg = "";
        if (form.Amount <= 0)        { errorMsg = "Please enter a valid amount greater than $0."; return; }
        if (form.CategoryId == 0)    { errorMsg = "Please select a category."; return; }
        if (string.IsNullOrWhiteSpace(form.Description)) { errorMsg = "Please enter a description."; return; }

        isSaving = true;
        bool success = editId.HasValue
            ? await TransactionService.Update(editId.Value, form)
            : await TransactionService.Create(form);
        isSaving = false;

        if (success) { CloseModal(); await LoadTransactions(); }
        else errorMsg = "Something went wrong. Please try again.";
    }

    // ── Delete ────────────────────────────────────────────────────────────────
    private void ConfirmDelete(TransactionDto t)
    {
        deletingTransaction = t;
        showDeleteConfirm = true;
    }

    private async Task DeleteConfirmed()
    {
        if (deletingTransaction == null) return;
        showDeleteConfirm = false;
        if (await TransactionService.Delete(deletingTransaction.Id))
            transactions.RemoveAll(t => t.Id == deletingTransaction.Id);
        deletingTransaction = null;
    }
}
